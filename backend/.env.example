# Crypto Volatility Scanner - Environment Variables
# Copy this file to .env and fill in your values (if needed)

# ============================================================================
# BINANCE API (Optional - currently not used)
# ============================================================================
# This project uses Binance PUBLIC endpoints only (no API key required).
# If you want to extend it with authenticated endpoints, add your keys here:
# BINANCE_API_KEY=your_api_key_here
# BINANCE_API_SECRET=your_secret_key_here

# ============================================================================
# SERVER CONFIGURATION (Optional)
# ============================================================================
# Backend server settings
# HOST=0.0.0.0
# PORT=8000
# DEBUG=false

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ============================================================================
# BINANCE API SETTINGS (Optional overrides)
# ============================================================================
# Override default Binance settings if needed
# BINANCE_BASE_URL=https://api.binance.com/api/v3
# BATCH_SIZE=50
# BATCH_DELAY=0.15
# MIN_VOLUME_USDT=100000
# KLINE_INTERVAL=1m
# KLINE_LIMIT=16

# ============================================================================
# RATE LIMITING (Optional)
# ============================================================================
# Binance rate limit (weight per minute)
# RATE_LIMIT_WEIGHT=1200

# ============================================================================
# WEBHOOKS / ALERTS (Optional - for future extensions)
# ============================================================================
# If you add alert functionality, configure webhooks here:
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ============================================================================
# DATABASE (Optional - for future extensions)
# ============================================================================
# If you add historical data storage:
# DATABASE_URL=sqlite:///./crypto_scanner.db
# or
# DATABASE_URL=postgresql://user:password@localhost:5432/crypto_scanner

# ============================================================================
# LOGGING (Optional)
# ============================================================================
# LOG_LEVEL=INFO
# LOG_FORMAT=json
