# Crypto Volatility Scanner - Frontend Environment Variables
# Copy this file to .env and fill in your values (if needed)

# ============================================================================
# BACKEND API URL
# ============================================================================
# In development, Vite proxy handles /api/* requests to backend
# In production, set the full backend URL:
# VITE_API_BASE_URL=http://localhost:8000

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================
# VITE_PORT=5173
# VITE_HOST=localhost

# ============================================================================
# FEATURE FLAGS (Optional - for future extensions)
# ============================================================================
# VITE_ENABLE_CHARTS=false
# VITE_ENABLE_ALERTS=false
# VITE_ENABLE_HISTORY=false

# ============================================================================
# REFRESH SETTINGS (Optional overrides)
# ============================================================================
# Auto-refresh interval in seconds (default: 60)
# VITE_AUTO_REFRESH_SECONDS=60
